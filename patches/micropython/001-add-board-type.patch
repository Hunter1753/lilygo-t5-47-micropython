diff --git a/ports/esp32/boards/LILYGO_T5_47/mpconfigboard.cmake b/ports/esp32/boards/LILYGO_T5_47/mpconfigboard.cmake
new file mode 100644
index 000000000..8023217eb
--- /dev/null
+++ b/ports/esp32/boards/LILYGO_T5_47/mpconfigboard.cmake
@@ -0,0 +1,24 @@
+set(IDF_TARGET esp32)
+
+set(SDKCONFIG_DEFAULTS
+    boards/sdkconfig.base
+    boards/sdkconfig.ble
+    boards/sdkconfig.240mhz
+    boards/sdkconfig.spiram
+    boards/${MICROPY_BOARD}/sdkconfig.board
+)
+
+# Add epdiy as an IDF component.
+# EXTRA_COMPONENT_DIRS must be set before project.cmake is included.
+# mpconfigboard.cmake is included at line ~38 of ports/esp32/CMakeLists.txt,
+# before the project.cmake include at line ~63, so this placement is correct.
+get_filename_component(_EPDIY_DIR
+    "${CMAKE_CURRENT_LIST_DIR}/../../../../../epdiy" ABSOLUTE)
+list(APPEND EXTRA_COMPONENT_DIRS "${_EPDIY_DIR}")
+
+# esp32_common.cmake calls: idf_component_register(REQUIRES ${IDF_COMPONENTS})
+# Appending epdiy here ensures it appears in that REQUIRES list so that
+# the MicroPython IDF component links against it.
+list(APPEND IDF_COMPONENTS epdiy)
+
+set(MICROPY_FROZEN_MANIFEST ${MICROPY_BOARD_DIR}/manifest.py)
