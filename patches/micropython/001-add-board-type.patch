diff --git a/ports/esp32/boards/LILYGO_T5_47/sdkconfig.board b/ports/esp32/boards/LILYGO_T5_47/sdkconfig.board
new file mode 100644
index 000000000..41729679d
--- /dev/null
+++ b/ports/esp32/boards/LILYGO_T5_47/sdkconfig.board
@@ -0,0 +1,13 @@
+# LilyGo T5 4.7" specific sdkconfig overrides
+
+# Flash: QIO mode at 80 MHz, 16 MB
+CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
+CONFIG_ESPTOOLPY_FLASHFREQ_80M=y
+CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
+
+# PSRAM: 80 MHz quad mode
+# (sdkconfig.spiram already enables CONFIG_SPIRAM, cache workaround, and MALLOC)
+CONFIG_SPIRAM_SPEED_80M=y
+
+# Minimum silicon revision: ESP32-D0WQ6 is rev 3
+CONFIG_ESP32_REV_MIN_3=y
